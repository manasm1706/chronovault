<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme - Light mode only -->
    <style name="Theme.ChronoVault" parent="Theme.Material3.Light">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryContainer">@color/primary_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>

        <!-- Secondary colors -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_light</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorOnSecondaryContainer">@color/text_primary</item>

        <!-- Tertiary/Accent colors -->
        <item name="colorTertiary">@color/accent</item>
        <item name="colorOnTertiary">@color/white</item>

        <!-- Status/semantic colors -->
        <item name="colorError">@color/error</item>
        <item name="colorErrorContainer">#ffecdcd5</item>
        <item name="colorOnError">@color/white</item>
        <item name="colorOnErrorContainer">@color/error</item>

        <!-- Surface colors -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <!-- Outline -->
        <item name="colorOutline">@color/border</item>
        <item name="colorOutlineVariant">@color/divider</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Typography - Roboto -->
        <item name="fontFamily">@font/roboto</item>
        <item name="android:fontFamily">@font/roboto</item>

        <!-- Text appearances -->
        <item name="textAppearanceDisplayLarge">@style/TextAppearance.ChronoVault.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/TextAppearance.ChronoVault.DisplayMedium</item>
        <item name="textAppearanceDisplaySmall">@style/TextAppearance.ChronoVault.DisplaySmall</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.ChronoVault.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.ChronoVault.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.ChronoVault.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.ChronoVault.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.ChronoVault.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.ChronoVault.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.ChronoVault.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.ChronoVault.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.ChronoVault.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.ChronoVault.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.ChronoVault.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.ChronoVault.LabelSmall</item>

        <!-- Shape appearance for rounded corners -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.ChronoVault.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.ChronoVault.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.ChronoVault.LargeComponent</item>

        <!-- Component styles -->
        <item name="buttonStyle">@style/Widget.ChronoVault.Button</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.ChronoVault.OutlinedButton</item>
        <item name="materialButtonTonalStyle">@style/Widget.ChronoVault.TonalButton</item>
        <item name="cardViewStyle">@style/Widget.ChronoVault.CardView</item>
    </style>

    <!-- Typography Styles -->
    <style name="TextAppearance.ChronoVault.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:fontFamily">@font/roboto_bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.ChronoVault.DisplayMedium" parent="TextAppearance.Material3.DisplayMedium">
        <item name="android:fontFamily">@font/roboto_bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.ChronoVault.DisplaySmall" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:fontFamily">@font/roboto_bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.ChronoVault.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">@font/roboto_bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.ChronoVault.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">@font/roboto_bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.ChronoVault.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:fontFamily">@font/roboto_bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.ChronoVault.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/roboto_bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.ChronoVault.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">@font/roboto_bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.ChronoVault.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:fontFamily">@font/roboto</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.ChronoVault.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">@font/roboto</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.ChronoVault.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/roboto</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.ChronoVault.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="android:fontFamily">@font/roboto</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.ChronoVault.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">@font/roboto_bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.ChronoVault.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:fontFamily">@font/roboto_bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.ChronoVault.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">@font/roboto_bold</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Shape Appearance -->
    <style name="ShapeAppearance.ChronoVault.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.ChronoVault.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.ChronoVault.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <!-- Component Styles -->
    <style name="Widget.ChronoVault.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:paddingLeft">24dp</item>
        <item name="android:paddingRight">24dp</item>
    </style>

    <style name="Widget.ChronoVault.OutlinedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">24dp</item>
    </style>

    <style name="Widget.ChronoVault.TonalButton" parent="Widget.Material3.Button.TonalButton">
        <item name="cornerRadius">24dp</item>
    </style>

    <style name="Widget.ChronoVault.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
    </style>
</resources>